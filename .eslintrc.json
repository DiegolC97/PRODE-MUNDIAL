{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["next/core-web-vitals", "plugin:@typescript-eslint/recommended"],
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }]
  },
  "overrides": [
    {
      "files": ["src/domain/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@application/*", "@infrastructure/*", "@interfaces/*"],
                "message": "domain layer cannot import from application, infrastructure, or interfaces."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/application/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@infrastructure/*", "@interfaces/*"],
                "message": "application layer cannot import from infrastructure or interfaces."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/infrastructure/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@interfaces/*"],
                "message": "infrastructure layer cannot import from interfaces."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/modules/*/domain/**/*.ts", "src/modules/*/domain/**/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@/modules/*/application/*",
                  "@/modules/*/infrastructure/*",
                  "@/modules/*/presentation/*"
                ],
                "message": "module domain layer cannot import from application, infrastructure, or presentation."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/modules/*/application/**/*.ts", "src/modules/*/application/**/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/modules/*/infrastructure/*", "@/modules/*/presentation/*"],
                "message": "module application layer cannot import from infrastructure or presentation."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/modules/*/infrastructure/**/*.ts", "src/modules/*/infrastructure/**/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/modules/*/presentation/*"],
                "message": "module infrastructure layer cannot import from presentation."
              }
            ]
          }
        ]
      }
    }
  ],
  "ignorePatterns": ["node_modules/", ".next/", "out/", "dist/"]
}
