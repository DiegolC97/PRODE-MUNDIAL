{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": [
    "next/core-web-vitals",
    "plugin:@typescript-eslint/recommended"
  ],
  "plugins": ["@typescript-eslint"],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/no-explicit-any": "error",
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }]
  },
  "overrides": [
    {
      "files": ["src/domain/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@application/*", "@infrastructure/*", "@interfaces/*"],
                "message": "domain layer cannot import from application, infrastructure, or interfaces."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/application/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@infrastructure/*", "@interfaces/*"],
                "message": "application layer cannot import from infrastructure or interfaces."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/infrastructure/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@interfaces/*"],
                "message": "infrastructure layer cannot import from interfaces."
              }
            ]
          }
        ]
      }
    }
  ],
  "ignorePatterns": ["node_modules/", ".next/", "out/", "dist/"]
}
