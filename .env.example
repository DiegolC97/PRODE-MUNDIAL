# --- Next.js frontend / BFF ---
NEXT_PUBLIC_APP_NAME="PRODE MUNDIAL"
NODE_ENV=development

# --- Microservices URLs (used by the Next.js BFF) ---
MATCHES_SERVICE_URL=http://localhost:4001
PREDICTIONS_SERVICE_URL=http://localhost:4002
SCORING_SERVICE_URL=http://localhost:4003

# --- Microservice ports ---
MATCHES_SERVICE_PORT=4001
PREDICTIONS_SERVICE_PORT=4002
SCORING_SERVICE_PORT=4003

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=prode
POSTGRES_PASSWORD=prode_secret
POSTGRES_DB=prode_mundial
DATABASE_URL=postgres://prode:prode_secret@localhost:5432/prode_mundial

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- NextAuth (session signing) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_a_random_32_byte_secret
NEXTAUTH_URL=http://localhost:3000

# --- External APIs ---
# https://www.api-football.com/ — required for syncing fixtures and live results
API_FOOTBALL_KEY=replace_me_with_your_api_football_key
