// PRODE MUNDIAL — Prisma schema
//
// Mirrors scripts/init.sql so `prisma migrate dev` produces the same physical
// schema. Tables/columns use snake_case (matching SQL) via @map/@@map so that
// the generated TS client uses idiomatic camelCase.
//
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Teams ──────────────────────────────────────────────────────
model Team {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  countryCode String   @map("country_code") @db.Char(3)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")

  @@map("teams")
}

// ─── Matches ────────────────────────────────────────────────────
model Match {
  id         String   @id @default(uuid()) @db.Uuid
  homeTeamId String   @map("home_team_id") @db.Uuid
  awayTeamId String   @map("away_team_id") @db.Uuid
  kickoffAt  DateTime @map("kickoff_at") @db.Timestamptz(6)
  stage      String   @db.VarChar(40)
  homeScore  Int?     @map("home_score")
  awayScore  Int?     @map("away_score")
  status     String   @default("SCHEDULED") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  homeTeam    Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions Prediction[]

  @@index([kickoffAt], map: "matches_kickoff_idx")
  @@map("matches")
}

// ─── Users ──────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(200)
  username     String   @unique @db.VarChar(40)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(80)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  predictions Prediction[]
  profile     Profile?

  @@map("users")
}

// ─── Profiles ───────────────────────────────────────────────────
model Profile {
  id          String  @id @default(uuid()) @db.Uuid
  userId      String  @unique @map("user_id") @db.Uuid
  name        String  @db.VarChar(80)
  country     String  @db.Char(2)
  avatarUrl   String? @map("avatar_url") @db.Text
  totalScore  Int     @default(0) @map("total_score")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([totalScore], map: "profiles_total_score_idx")
  @@map("profiles")
}

// ─── Predictions ────────────────────────────────────────────────
model Prediction {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  matchId       String   @map("match_id") @db.Uuid
  predictedHome Int      @map("predicted_home")
  predictedAway Int      @map("predicted_away")
  pointsAwarded Int?     @map("points_awarded")
  submittedAt   DateTime @default(now()) @map("submitted_at") @db.Timestamptz(6)

  user  User  @relation(fields: [userId], references: [id])
  match Match @relation(fields: [matchId], references: [id])

  @@unique([userId, matchId])
  @@index([userId], map: "predictions_user_idx")
  @@map("predictions")
}
