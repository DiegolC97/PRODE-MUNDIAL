{
  "name": "prode-mundial",
  "version": "0.1.0",
  "private": true,
  "description": "PRODE MUNDIAL — World Cup prediction pool built with Next.js, TypeScript, microservices, PostgreSQL and Redis under Clean Architecture.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:migrate": "prisma migrate dev",
    "db:migrate:legacy": "node scripts/migrate.js",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node --compiler-options {\"module\":\"commonjs\"} prisma/seed.ts",
    "service:matches": "ts-node src/interfaces/services/matches-service/server.ts",
    "service:predictions": "ts-node src/interfaces/services/predictions-service/server.ts",
    "service:scoring": "ts-node src/interfaces/services/scoring-service/server.ts",
    "worker": "ts-node src/shared/queue/worker.ts"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"commonjs\"} prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.18.0",
    "bcryptjs": "2.4.3",
    "bullmq": "5.12.0",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "ioredis": "5.4.1",
    "next": "14.2.5",
    "next-auth": "4.24.11",
    "pg": "8.12.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.10",
    "@types/pg": "8.11.6",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@typescript-eslint/eslint-plugin": "7.16.0",
    "@typescript-eslint/parser": "7.16.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "jest": "29.7.0",
    "prettier": "3.3.2",
    "prisma": "5.18.0",
    "ts-jest": "29.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
